# ── Backend ─────────────────────────────────────────────────────
APP_ID=                   # Application ID
APP_SECRET=               # Application secret (used for JWT signing)

# ── Database ───────────────────────────────────────────────────
DATABASE_URL=             # MySQL connection string (mysql://user:pass@host:port/db)

# ── Frontend (exposed to browser via Vite) ──────────────────────
VITE_KIMI_AUTH_URL=       # Kimi OAuth server URL (e.g. https://auth.kimi.com)
VITE_APP_ID=              # OAuth application ID
# Full URL of the tRPC endpoint. Required when the frontend and backend
# are on different origins (e.g. GitHub Pages + Render). For local dev
# with the Vite proxy, leave unset and /api/trpc is used.
# Example: https://obsidian-arts-api.onrender.com/api/trpc
VITE_API_BASE_URL=
# In dev, the Vite server proxies /api/* to this target. Defaults to
# http://localhost:3001 if unset. Set if your backend runs elsewhere.
VITE_API_PROXY_TARGET=http://localhost:3001

# ── Backend (Auth) ─────────────────────────────────────────────
KIMI_AUTH_URL=            # Kimi OAuth server URL (backend)
KIMI_OPEN_URL=            # Kimi Open Platform URL (e.g. https://open.kimi.com)

# ── CORS ───────────────────────────────────────────────────────
# Full origin of the deployed frontend, e.g.
# https://m-hassssssan.github.io. Required when frontend and backend
# are on different origins. Add to the backend with `hono/cors`.
FRONTEND_ORIGIN=http://localhost:3000

# ── Admin Role ──────────────────────────────────────────────────
OWNER_UNION_ID=           # Union ID of the app creator; this user gets role "admin" on first login

# ── GitHub Integration (admin panel) ──────────────────────────
# Reads (commits, issues, PRs, releases, README) work without a token
# (60 req/h unauth). Writes (create issue, comment, push file, dispatch
# webhook) require a Personal Access Token with `repo` scope.
GITHUB_TOKEN=             # GitHub PAT (e.g. ghp_…). Optional, enables writes.
GITHUB_OWNER=             # Defaults to "m-hassssssan"
GITHUB_REPO=              # Defaults to "OBSIDIAN.ARTS"
